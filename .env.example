# Kopiraj ovaj fajl u .env i popuni vrijednosti

# ============================================================
# OBAVEZNO — Aplikacija neće raditi bez ovih varijabli
# ============================================================

# Lozinke za pristup (student i admin)
ACCESS_PASSWORD=your_student_password
ADMIN_PASSWORD=your_admin_password

# ============================================================
# OPCIONALNO — Za dodatne funkcionalnosti
# ============================================================

# Google Gemini API (za AI generiranje lekcija i testova)
GOOGLE_API_KEY=

# Ngrok (za remote pristup preko interneta)
NGROK_AUTH_TOKEN=
NGROK_DOMAIN=

# OCR alati (za atlas.py — obradu PDF atlasa)
# Na Linuxu: TESSERACT_CMD=tesseract, POPPLER_PATH= (prazno)
# Na Windowsu: pune putanje do instaliranih programa
TESSERACT_CMD=
POPPLER_PATH=
INPUT_PDF=sobotta-anatomski-atlas.pdf

# ============================================================
# RAZVOJ — Postavi DEBUG=1 za dev mode (zaobilazi obavezne lozinke)
# ============================================================
# DEBUG=1
# FLASK_ENV=development
